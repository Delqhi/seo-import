{
  "_comment": "Product Schema Template — For products/services",
  "_usage": "Fill in the values and inject into page <head>",
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{product.name}}",
  "description": "{{product.description}}",
  "brand": {
    "@type": "Brand",
    "name": "{{organization.name}}"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{product.url}}",
    "priceCurrency": "{{product.currency}}",
    "price": "{{product.price}}",
    "availability": "https://schema.org/{{product.availability}}",
    "seller": {
      "@type": "Organization",
      "name": "{{organization.name}}"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{product.rating}}",
    "reviewCount": "{{product.reviewCount}}",
    "bestRating": "5",
    "worstRating": "1"
  },
  "image": "{{product.image}}",
  "url": "{{product.url}}"
}
